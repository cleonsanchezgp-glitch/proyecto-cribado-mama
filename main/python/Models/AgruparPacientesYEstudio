import datetime

from main.python.Models import Paciente
from main.python.Models import Estudio



def agrupar_pacientes_y_estudios(lista_de_filas):
    """
    Recibe una lista de diccionarios (filas del CSV) y devuelve
    una lista de objetos Paciente con sus estudios agrupados.
    """
    pacientes_agrupados = {}

    for fila in lista_de_filas:
        # 1. Crear una clave única para identificar al paciente en ese estudio
        # Usamos Nombre + Edad + Fecha para asegurar que es la misma sesión
        id_unico = (fila['Paciente'], fila['Edad'], fila['Fecha Realización'])

        # 2. Si el paciente no está en el diccionario, lo creamos
        if id_unico not in pacientes_agrupados:
            f_obj = datetime.strptime(fila['Fecha Realización'], "%Y-%m-%d").date()
            
            pacientes_agrupados[id_unico] = Paciente(
                nombre=fila['Paciente'],
                edad=int(fila['Edad']),
                fecha_realizacion=f_obj
            )

        # 3. Creamos el objeto Estudio para esta exposición individual
        h_str = fila['Hora Adquisición']
        h_obj = datetime.strptime(h_str, "%H:%M:%S").time() if h_str else None
        
        nuevo_estudio = Estudio(
            tipo_actividad=fila['Tipo Actividad'],
            prestacion_realizada=fila['Prestación Realizada'],
            hora_adquisicion=h_obj
        )

        # 4. Agregamos el estudio al paciente correspondiente
        pacientes_agrupados[id_unico].agregar_estudio(nuevo_estudio)

    return list(pacientes_agrupados.values())